<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.github.drakescraft_labs</groupId>
        <artifactId>drakes-slimefun-labs</artifactId>
        <version>11-SNAPSHOT</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>

    <groupId>com.github.drakescraft_labs</groupId>
    <artifactId>Aircraft-drake</artifactId>
    <version>0.1-Drake-1.21.1-SNAPSHOT</version>
    <packaging>jar</packaging>

    <name>Aircraft (DrakesCraft Labs fork)</name>
    <description>
        Slimefun aircraft addon (upstream: metamechanists/Aircraft-dev, originally LordIdra/Aircraft).
        Build target: Paper API ${paper.version}. Runtime requires KinematicCore + ProtocolLib + Slimefun.
    </description>

    <properties>
        <maven.deploy.skip>true</maven.deploy.skip>
        <!-- MetaMechanists libs: bump if upstream publishes versions built against newer Paper -->
        <metalib.version>80</metalib.version>
        <displaymodellib.version>33</displaymodellib.version>
        <kinematiccore.version>33-DRAKE-1.21.11-SNAPSHOT</kinematiccore.version>
        <invui.version>1.49</invui.version>
    </properties>

    <repositories>
        <repository>
            <id>papermc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>
        <repository>
            <id>metamechanists</id>
            <url>https://repo.metamechanists.org/releases/</url>
        </repository>
        <repository>
            <id>jitpack.io</id>
            <url>https://jitpack.io</url>
        </repository>
        <repository>
            <id>aikar</id>
            <url>https://repo.aikar.co/content/groups/aikar/</url>
        </repository>
        <repository>
            <id>xenondevs</id>
            <url>https://repo.xenondevs.xyz/releases</url>
        </repository>
    </repositories>

    <dependencies>
        <dependency>
            <groupId>com.github.drakescraft_labs</groupId>
            <artifactId>drakes-labs-autoupdate</artifactId>
        </dependency>

        <dependency>
            <groupId>io.papermc.paper</groupId>
            <artifactId>paper-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>com.github.drakescraft_labs</groupId>
            <artifactId>slimefun-core</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>com.github.drakescraft_labs</groupId>
            <artifactId>sefilib-drake</artifactId>
            <version>${sefilib.version}</version>
            <scope>compile</scope>
        </dependency>

        <dependency>
            <groupId>org.metamechanists</groupId>
            <artifactId>MetaLib</artifactId>
            <version>${metalib.version}</version>
            <scope>compile</scope>
        </dependency>

        <dependency>
            <groupId>org.metamechanists</groupId>
            <artifactId>DisplayModelLib</artifactId>
            <version>${displaymodellib.version}</version>
            <scope>compile</scope>
        </dependency>

        <dependency>
            <groupId>com.github.drakescraft_labs</groupId>
            <artifactId>kinematic-core-drake</artifactId>
            <version>${kinematiccore.version}</version>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>com.comphenix.protocol</groupId>
            <artifactId>ProtocolLib</artifactId>
            <version>5.3.0</version>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>co.aikar</groupId>
            <artifactId>acf-paper</artifactId>
            <scope>compile</scope>
        </dependency>

        <dependency>
            <groupId>xyz.xenondevs.invui</groupId>
            <artifactId>invui</artifactId>
            <version>${invui.version}</version>
            <scope>compile</scope>
            <type>pom</type>
        </dependency>
    </dependencies>

    <build>
        <!-- Sin espacios: coincide con el nombre desplegado en servidores (Aircraft-drake-*.jar). -->
        <finalName>${project.artifactId}-${project.version}</finalName>
        <defaultGoal>clean package</defaultGoal>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.15.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                    <release>21</release>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>${maven.shade.plugin.version}</version>
                <configuration>
                    <relocations>
                        <relocation>
                            <pattern>org.metamechanists.metalib</pattern>
                            <shadedPattern>org.metamechanists.aircraft.metalib</shadedPattern>
                        </relocation>
                        <relocation>
                            <pattern>org.metamechanists.displaymodellib</pattern>
                            <shadedPattern>org.metamechanists.aircraft.displaymodellib</shadedPattern>
                        </relocation>
                        <relocation>
                            <pattern>co.aikar</pattern>
                            <shadedPattern>org.metamechanists.aircraft.co.aikar</shadedPattern>
                        </relocation>
                        <relocation>
                            <pattern>xyz.xenondevs.invui</pattern>
                            <shadedPattern>org.metamechanists.aircraft.invui</shadedPattern>
                        </relocation>
                        <relocation>
                            <pattern>xyz.xenondevs.inventoryaccess</pattern>
                            <shadedPattern>org.metamechanists.aircraft.inventoryaccess</shadedPattern>
                        </relocation>
                    </relocations>
                    <filters>
                        <filter>
                            <artifact>*:*</artifact>
                            <excludes>
                                <exclude>META-INF/*</exclude>
                            </excludes>
                        </filter>
                    </filters>
                </configuration>
                <executions>
                    <execution>
                        <phase>package</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
            </resource>
        </resources>
    </build>
</project>
